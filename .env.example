# ============================================================================
# CastCore — environment configuration
# Copy to .env and adjust. NEVER commit your real .env.
# ============================================================================

# --- General ---
CASTCORE_ENV=production            # production | development
DOMAIN=localhost                   # public hostname used by the reverse proxy
TZ=Europe/Berlin
DEFAULT_LANGUAGE=de                # de | en  (Setup Wizard can override)

# --- Security (CHANGE THESE) ---
# With CASTCORE_ENV=production the backend REFUSES TO START while these still hold their
# insecure defaults (the "changeme" placeholders / the default DB password). Development and
# tests keep the convenient defaults.
# 64+ hex chars. Generate: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
# Fernet key for encrypting stored secrets (stream keys, SMB/OAuth credentials).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme_generate_a_fernet_key
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14
# Rate limiting for sensitive auth endpoints (login/refresh/2fa-verify/token-create/setup-admin).
# Redis-backed, fixed window; fails open if Redis is unreachable.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_ATTEMPTS=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=300

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=castcore
POSTGRES_USER=castcore
POSTGRES_PASSWORD=changeme_db_password

# --- Redis (cache / queue / pubsub) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Paths (inside containers / native data root) ---
DATA_DIR=/data
MEDIA_DIR=/data/media
RECORDINGS_DIR=/data/recordings
LOG_DIR=/data/logs
BACKUP_DIR=/data/backups
MOUNT_DIR=/data/mounts
THUMBNAIL_DIR=/data/thumbnails

# --- FFmpeg / ffprobe provisioning (build-time; CVE-2026-8461 -> require >= 8.1.2) ---
# How the Docker images obtain ffmpeg/ffprobe:
#   copy   (default, recommended) multi-stage COPY from a pinned, static image (FFMPEG_IMAGE)
#   static download a static tarball and verify FFMPEG_STATIC_SHA256 (also set FFMPEG_STATIC_URL)
#   apt    Debian package (may be < 8.1.2; NOT recommended — runtime will warn)
# For copy/static the image build FAILS if ffmpeg/ffprobe is below 8.1.2.
FFMPEG_VARIANT=copy
# Pinned static source image for the "copy" variant. Always pin tag + digest; never use a bare
# tag or "latest". ffmpeg and ffprobe come from the same build/version.
FFMPEG_IMAGE=mwader/static-ffmpeg:8.1.2@sha256:33f770f812cbfc3de96c547157fc9faf8bd95a36481753439ffa761045167585
# Only for FFMPEG_VARIANT=static: URL of a >=8.1.2 static tarball and its SHA256 checksum.
FFMPEG_STATIC_URL=
FFMPEG_STATIC_SHA256=

# --- FFmpeg (runtime paths inside the containers) ---
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# --- Reverse proxy / HTTPS (Caddy) ---
# For real certificates set DOMAIN to a public hostname and ACME_EMAIL.
ACME_EMAIL=

# --- Content-Security-Policy (set by Caddy; see docs admin-guide/security) ---
# CSP_ENABLED=false      -> no CSP header at all
# CSP_ENABLED=true  + CSP_REPORT_ONLY=true  -> Content-Security-Policy-Report-Only (default;
#   browsers report violations but nothing is blocked)
# CSP_ENABLED=true  + CSP_REPORT_ONLY=false -> Content-Security-Policy (enforced)
# Values must be exactly "true" or "false". The policy is domain-agnostic ('self' only).
CSP_ENABLED=true
CSP_REPORT_ONLY=true

# --- Preflight (gate before stream start) ---
# Require a fresh preflight report before a stream may start, and/or block start on a red
# (blocking-error) report. Admins can override (audited). TTL marks reports stale.
PREFLIGHT_REQUIRED_BEFORE_START=false
PREFLIGHT_BLOCK_ON_RED=false
PREFLIGHT_REPORT_TTL_SECONDS=600

# --- Safe media processing (FFmpeg decoder CVE mitigation, e.g. CVE-2026-8461/MagicYUV) ---
# Treat media from untrusted sources cautiously; flag/block risky codecs instead of
# decoding them automatically. See docs admin-guide/ffmpeg-requirements.
SAFE_MEDIA_PROCESSING_ENABLED=true
MEDIA_AUTOTHUMBNAILS_ENABLED=true
BLOCK_RISKY_CODECS=true
# Comma-separated extra codecs to treat as risky (merged with the built-in defaults).
RISKY_CODECS_BLOCKLIST=magicyuv

# --- Optional MediaMTX integration (compose profile: mediamtx) ---
MEDIAMTX_ENABLED=false
MEDIAMTX_API_URL=http://mediamtx:9997
# Base URL FFmpeg uses to pull an ingest path back in as a source.
MEDIAMTX_RTSP_URL=rtsp://mediamtx:8554

# --- Platform OAuth (optional; connect YouTube/Twitch accounts) ---
# Public URL of this instance (scheme + host, no trailing slash). Required for OAuth:
# the provider redirects to PUBLIC_BASE_URL/api/v1/oauth/<provider>/callback.
PUBLIC_BASE_URL=
# Leave a provider's client id empty to disable it. Keep secrets out of version control.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
