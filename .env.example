# ============================================================================
# CastCore — environment configuration
# Copy to .env and adjust. NEVER commit your real .env.
# ============================================================================

# --- General ---
CASTCORE_ENV=production            # production | development
DOMAIN=localhost                   # public hostname used by the reverse proxy
TZ=Europe/Berlin
DEFAULT_LANGUAGE=de                # de | en  (Setup Wizard can override)

# --- Security (CHANGE THESE) ---
# 64+ hex chars. Generate: openssl rand -hex 32
SECRET_KEY=changeme_generate_with_openssl_rand_hex_32
# Fernet key for encrypting stored secrets (stream keys, SMB/OAuth credentials).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme_generate_a_fernet_key
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=castcore
POSTGRES_USER=castcore
POSTGRES_PASSWORD=changeme_db_password

# --- Redis (cache / queue / pubsub) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Paths (inside containers / native data root) ---
DATA_DIR=/data
MEDIA_DIR=/data/media
RECORDINGS_DIR=/data/recordings
LOG_DIR=/data/logs
BACKUP_DIR=/data/backups
MOUNT_DIR=/data/mounts
THUMBNAIL_DIR=/data/thumbnails

# --- FFmpeg ---
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe

# --- Reverse proxy / HTTPS (Caddy) ---
# For real certificates set DOMAIN to a public hostname and ACME_EMAIL.
ACME_EMAIL=

# --- Optional MediaMTX integration (compose profile: mediamtx) ---
MEDIAMTX_ENABLED=false
MEDIAMTX_API_URL=http://mediamtx:9997
